# ============================================================
#  Free Fire Auto-Like Bot - Environment Variables
#  Ei file copy kore ".env" name e save koro, tarpor value gula bosao.
# ============================================================

# ---- REQUIRED (shudhu eitai lagbe) ----
# Telegram bot token (BotFather theke pabe: https://t.me/BotFather)
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWxyZ

# ---- OPTIONAL ----
# LIKE_API_URL khali rakhle bot ekta DEFAULT public like API try korbe
# (bot.py er DEFAULT_LIKE_ENDPOINTS list theke, ekta down hole porer ta).
#
# ⚠️ Garena official like API dey na. Default public API gula FREE - tai
#    maje maje down thake ba rate-limit kore (guarantee nai). Bondho hole
#    ekhane tomar nijer / onno kaj kora endpoint boshao:
#    Bot GET pathay: <URL>?uid=<uid>&region=bd&key=<LIKE_API_KEY>
# LIKE_API_URL=https://your-like-api.example.com/like
LIKE_API_URL=

# API key (jodi tomar API key chai). Na lagle khali rakho.
LIKE_API_KEY=

# Protidin koto like pathabe (configurable). Default 200. 300 dile 300.
DAILY_LIKES=200

# Region (default bd)
REGION=bd

# Daily scheduler kokhon cholbe (server timezone, 24h format). Default 00:05.
SCHEDULE_HOUR=0
SCHEDULE_MINUTE=5

# Timezone (e.g. Asia/Dhaka). Default UTC.
TZ=Asia/Dhaka

# HTTP request timeout (seconds)
HTTP_TIMEOUT=30

# SQLite database file path
DB_PATH=likebot.db
